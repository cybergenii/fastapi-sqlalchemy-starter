# App
ENV_TYPE=development
ENABLE_PERF_LOGS=true

# Database (async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_starter

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRY_TIME=3600
JWT_REFRESH_EXPIRY_TIME=86400
JWT_EXPIRY_TIME=3600

# Mail (optional)
USE_MAIL_SERVICE=false
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
USE_CREDENTIALS=true
MAIL_USE_SSL=false
MAIL_USE_TLS=true
MAIL_SENDER=noreply@example.com
MAIL_SENDER_NAME=FastAPI Starter

# Social OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/social/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/social/facebook/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/social/github/callback

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis cache (optional)
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
ENABLE_QUERY_LOGGING=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Payment gateways (optional — fill in when needed)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
PAYMENT_CALLBACK_URL=http://localhost:3000/payment/callback
PAYMENT_WEBHOOK_URL=http://localhost:8000/api/v1/payment/webhook
